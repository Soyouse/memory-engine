{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/bootstrap.js\"" },
          { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/memory-bump.js\"" },
          { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/memory-reindex.js\" --reconcile" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/memory-suggest.js\"" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/memory-guard.js\"" },
          { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/memory-autoindex.js\"" }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/memory-bump.js\"" }
        ]
      }
    ]
  }
}
